# ─── Real Estate — Lead-to-Close Automation ─────────────────────────────────
# All authentication is handled through n8n credentials (no env vars required).
# The values below are hardcoded in workflow nodes — update them directly in n8n.

# ─── W1: Lead Intake & Qualification ─────────────────────────────────────────

# ClickUp list IDs
CLICKUP_ACTIVE_LEADS_LIST_ID=901522903678
CLICKUP_NURTURE_LIST_ID=901522903680

# Slack channel for qualified lead alerts
SLACK_LEADS_CHANNEL=#messages

# ─── W2: Transaction Launch ───────────────────────────────────────────────────

# Google Drive root folder where all client folders are created
# Find it in the Drive URL: drive.google.com/drive/folders/FOLDER_ID
DRIVE_CLIENTS_PARENT_FOLDER_ID=

# ClickUp workspace (team) ID — curl https://api.clickup.com/api/v2/team | jq '.teams[0].id'
CLICKUP_WORKSPACE_ID=

# ClickUp space ID — curl https://api.clickup.com/api/v2/team/$TEAM/space | jq '.spaces[].id'
CLICKUP_SPACE_ID=

# ClickUp API token — used in ClickUp credential in n8n (not hardcoded)
CLICKUP_API_TOKEN=pk_...

# Slack channel for new client alerts
SLACK_ALERT_CHANNEL=#messages

# Internal email address for project briefs
AGENT_EMAIL=agent@yourbrokerage.com

# ─── Shared ───────────────────────────────────────────────────────────────────

# Your n8n public URL (for webhook registration)
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com
