    {
      "parameters": {
        "promptType": "define",
        "text": "=A customer has left a negative review on our Google Business Profile. Draft a response that acknowledges their experience with genuine empathy, maintains a calm and professional tone, and warmly invites them back for a better experience.\n\n\nReviewer: {{ $json.body.reviewer }}\nRating: {{ $json.body.rating }} / 5\nDate: {{ $json.body.time }}\nReview: {{ $json.body.review }}",
        "options": {
          "systemMessage": "=You are a customer experience professional drafting responses to negative Google reviews on behalf of the business. Your objective is to de-escalate tension, show genuine empathy, and protect the reputation of the business through clear and thoughtful communication.\n\nYour response must:\n- Be between 3 and 5 sentences\n- Acknowledge the customer's experience with sincerity\n- Invite the customer back warmly without making promises you cannot guarantee\n- Never open with \"We're sorry to hear\" or \"We apologize for\"\n- Never use dashes or hyphens anywhere in the response\n- Never use placeholder text like [Manager Name] or [Your Name]\n- Never argue with, deflect, or subtly place blame on the customer"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -688,
        856
      ],
      "id": "f71c2cbb-1fa5-4481-9f71-9e695048cb14",
      "name": "Negative Review Agent",
      "alwaysOutputData": false
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=A customer has left a positive review on our Google Business Profile. Draft a warm, appreciative response that makes them feel personally seen and valued.\n\nReviewer: {{ $json.body.reviewer }}\nRating: {{ $json.body.rating }} / 5\nDate: {{ $json.body.time }}\nReview: {{ $json.body.review }}",
        "options": {
          "systemMessage": "=You are a professional customer experience representative responding to positive Google reviews on behalf of the business. Your tone is warm, genuine, and conversational — like the owner speaking directly to a friend.\n\nRules you must follow without exception:\n- Never use dashes (hyphens) anywhere in your response\n- Never open with \"Thank you so much for your review\" or \"We appreciate your feedback\" — these feel templated\n- Never use placeholder text like [Owner Name] or [Your Name]\n- Reference something specific from the review so it feels personal, not generic\n- Stay between 100 and 250 characters\n- Sound like a real person wrote this, not a bot"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -688,
