    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=A human reviewer has rejected the draft below and provided feedback. Revise it accordingly. Your output should only include the official review response, no additional comments.\n\nOriginal review from customer:\n{{ $('Webhook').item.json.body.review }}\n\nPrevious draft (rejected):\n{{ $('Edit Fields').item.json.response }}\n\nReviewer feedback:\n{{ $json.data.text }}",
        "options": {
          "systemMessage": "=You are a professional customer experience representative revising a Google Business review response on behalf of the business.\n\nYour revised response must:\n- Directly address the feedback provided by the human reviewer\n- Sound distinctly different in structure and wording from the previous draft\n- Be warm, sincere, and human — never robotic or corporate\n- Never use dashes (hyphens) anywhere in the response\n- Never open with \"We're sorry to hear\" or \"We apologize for\"\n- Never use placeholder text like [Manager Name] or [Your Name]\n- Stay between 3 and 5 sentences\n- Invite the customer back with a warm, specific offer to make things right"
        }
      },
