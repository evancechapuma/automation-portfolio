    {
      "parameters": {
        "inputText": "={{ $json.data.text }}",
        "categories": {
          "categories": [
            {
              "category": "Approved",
              "description": "=The human has reviewed the response and is satisfied with it. \nThis includes any message that signals acceptance, agreement, or readiness \nto send — even if brief or informal.\n\nAny message that does NOT contain feedback, edits, or revision requests \nshould be classified here by default.\n\nExample phrases include:\n\"Approved\", \"looks good\", \"good\", \"no changes needed\", \"I like it\", \n\"good to go\", \"send it\", \"yes\", \"perfect\", \"ok\", \"okay\", \"sure\", \n\"go ahead\", \"that works\", \"sounds good\", \"nice\", \"great\""
            },
            {
              "category": "Denied",
              "description": "=The human wants the response changed before it is sent. This includes \nany message containing feedback, instructions, criticism, suggestions, \nor edits — even if politely or vaguely worded.\n\nIf the message contains ANY request for change, no matter how small, \nclassify it here.\n\nExample phrases include:\n\"remove this\", \"take this out\", \"replace this with\", \"be more concise\", \n\"make it shorter\", \"too long\", \"too formal\", \"rewrite this\", \"change the tone\", \n\"don't mention\", \"fix this\", \"try again\", \"not quite\", \"needs work\", \n\"can you make it\", \"be concise\", \"add something about\""
            }
          ]
        },
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.textClassifier",
      "typeVersion": 1.1,
      "position": [
        112,
        732
