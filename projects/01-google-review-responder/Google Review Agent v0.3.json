      "parameters": {
        "operation": "sendAndWait",
        "sendTo": "robert.green1295@gmail.com",
        "subject": "[APPROVAL REQUIRED] New Review:",
        "message": "=Hello Jack,\n\nA new negative review was posted on your Google Business Profile and may require a response.\n\nReview Details\n\nReviewer: {{ $('Webhook').item.json.body.reviewer }}\nRating: {{ $('Webhook').item.json.body.rating }}\nDate: {{ $('Webhook').item.json.body.time }}\n\nCustomer Review:\n\"{{ $('Webhook').item.json.body.review }}\"\n---\n\nSuggested Response:\n\n{{ $json.response }}\n\n---\n\nPlease approve or deny the sending of this message generated by Jim, our AI review responder.\n\nReminder:\n\nResponding quickly to reviews helps maintain your reputation and shows customers that feedback matters.\n\nIf you have any questions or would like to adjust how responses are handled, feel free to shoot me a message.\n",
        "responseType": "freeText",
        "options": {
          "responseFormDescription": "=",
          "appendAttribution": false
        }
      },
