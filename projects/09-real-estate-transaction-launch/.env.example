# ─── Real Estate — Transaction Launch ───────────────────────────────────────
# All authentication is handled through n8n credentials (no env vars required).
# The values below are hardcoded in workflow nodes — update them directly in n8n.

# ─── Google Drive ────────────────────────────────────────────────────────────
# Root folder where all client folders are created
# Find it in the Drive URL: drive.google.com/drive/folders/FOLDER_ID
DRIVE_CLIENTS_PARENT_FOLDER_ID=

# ─── ClickUp ─────────────────────────────────────────────────────────────────
# Workspace (team) ID — curl https://api.clickup.com/api/v2/team | jq '.teams[0].id'
CLICKUP_WORKSPACE_ID=

# Space ID — curl https://api.clickup.com/api/v2/team/$TEAM/space | jq '.spaces[].id'
CLICKUP_SPACE_ID=

# API token — used in ClickUp credential in n8n (not hardcoded)
CLICKUP_API_TOKEN=pk_...

# ─── Slack ────────────────────────────────────────────────────────────────────
# Channel name for new client alerts (e.g. #messages, #new-clients)
SLACK_ALERT_CHANNEL=#messages

# ─── Agent / Brokerage ───────────────────────────────────────────────────────
# Email address for internal project briefs
AGENT_EMAIL=agent@yourbrokerage.com

# ─── n8n ─────────────────────────────────────────────────────────────────────
# Your n8n public URL (for webhook registration)
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com
